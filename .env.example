# ── AllKnower Environment Variables ──────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (via Prisma)
# Default port shifted to 5433 to avoid common host conflicts with other Postgres instances.
# AllKnower supports automatic fallback to 5432, 5434, and 5435 if connection fails.
DATABASE_URL=postgresql://allknower:allknower@localhost:5433/allknower

# better-auth
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3001

# v1 backend integrations
# Required in production. Use 32 utf8 bytes, 64 hex chars, or base64-encoded 32 bytes.
INTEGRATION_CREDENTIALS_KEY=change-me-32-byte-integration-key
# Required in production for Portal -> AllKnower internal credential lookup.
PORTAL_INTERNAL_SECRET=change-me-portal-secret

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Models — per-task primary + optional fallbacks
# Set to true to override all models with openrouter/auto
USE_OPENROUTER_AUTO=false

BRAIN_DUMP_MODEL=deepseek/deepseek-v4-pro
BRAIN_DUMP_FALLBACK_1=x-ai/grok-4.1-fast
BRAIN_DUMP_FALLBACK_2=qwen/qwen3.5-plus-02-15

# Article Copilot (defaults to BRAIN_DUMP_MODEL if not set)
# ARTICLE_COPILOT_MODEL=
# ARTICLE_COPILOT_FALLBACK_1=
# ARTICLE_COPILOT_FALLBACK_2=

CONSISTENCY_MODEL=deepseek/deepseek-v4-pro
CONSISTENCY_FALLBACK_1=z-ai/glm-5
CONSISTENCY_FALLBACK_2=xiaomi/mimo-v2-pro

SUGGEST_MODEL=google/gemini-3.1-flash-lite-preview
SUGGEST_FALLBACK_1=xiaomi/mimo-v2-flash
SUGGEST_FALLBACK_2=minimax/minimax-m2.7

GAP_DETECT_MODEL=deepseek/deepseek-v4-pro
GAP_DETECT_FALLBACK_1=anthropic/claude-sonnet-4.6
GAP_DETECT_FALLBACK_2=openai/gpt-oss-120b

AUTOCOMPLETE_MODEL=google/gemini-3.1-flash-lite-preview
AUTOCOMPLETE_FALLBACK_1=openai/gpt-5-nano
AUTOCOMPLETE_FALLBACK_2=xiaomi/mimo-v2-flash

# Reranker (native OpenRouter /rerank endpoint)
RERANK_MODEL=cohere/rerank-4-pro
RERANK_FALLBACK_1=
RERANK_FALLBACK_2=x-ai/grok-4.1-fast

# Embedding Models
EMBEDDING_CLOUD=qwen/qwen3-embedding-8b

# LanceDB (embedded — path to local DB directory)
LANCEDB_PATH=./data/lancedb

# AllCodex ETAPI (Trilium REST API)
ALLCODEX_URL=http://localhost:8080
ALLCODEX_ETAPI_TOKEN=your-etapi-token-from-allcodex-settings

# AllCodex server password — used by bootstrap to auto-create ETAPI tokens.
# Only needed for initial setup; once a token is obtained, this is not used again.
# ALLCODEX_PASSWORD=

# Portal-to-AllKnower internal secret — must match Portal's PORTAL_INTERNAL_SECRET.
# Dev default: "dev-portal-secret-32chars!!!" (auto-used in non-production).
# PORTAL_INTERNAL_SECRET=

# Rate limiting
BRAIN_DUMP_RATE_LIMIT_MAX=10
BRAIN_DUMP_RATE_LIMIT_WINDOW_MS=60000
