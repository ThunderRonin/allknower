# ── AllKnower Environment Variables ──────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (via Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/allknower

# better-auth
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3001

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Models — per-task primary + optional fallbacks
# Set to true to override all models with openrouter/auto
USE_OPENROUTER_AUTO=false

BRAIN_DUMP_MODEL=minimax/minimax-m2.5
BRAIN_DUMP_FALLBACK_1=x-ai/grok-4.1-fast
BRAIN_DUMP_FALLBACK_2=qwen/qwen3.5-plus-02-15

CONSISTENCY_MODEL=moonshotai/kimi-k2.5
CONSISTENCY_FALLBACK_1=z-ai/glm-5
CONSISTENCY_FALLBACK_2=anthropic/claude-3-7-sonnet

SUGGEST_MODEL=openai/gpt-4o-mini
SUGGEST_FALLBACK_1=anthropic/claude-3-7-sonnet
SUGGEST_FALLBACK_2=xiaomi/mimo-v2-flash

GAP_DETECT_MODEL=google/gemini-2.0-pro-exp-02-05
GAP_DETECT_FALLBACK_1=anthropic/claude-3-7-sonnet
GAP_DETECT_FALLBACK_2=openai/gpt-4o

AUTOCOMPLETE_MODEL=liquid/lfm-24b
AUTOCOMPLETE_FALLBACK_1=
AUTOCOMPLETE_FALLBACK_2=x-ai/grok-4.1-fast

# Reranker (LLM-as-a-Judge for complex queries)
RERANK_MODEL=openai/gpt-5-nano
RERANK_FALLBACK_1=
RERANK_FALLBACK_2=x-ai/grok-4.1-fast

# Embedding Models
EMBEDDING_CLOUD=qwen/qwen3-embedding-8b

# LanceDB (embedded — path to local DB directory)
LANCEDB_PATH=./data/lancedb

# AllCodex ETAPI (Trilium REST API)
ALLCODEX_URL=http://localhost:8080
ALLCODEX_ETAPI_TOKEN=your-etapi-token-from-allcodex-settings

# Rate limiting
BRAIN_DUMP_RATE_LIMIT_MAX=10
BRAIN_DUMP_RATE_LIMIT_WINDOW_MS=60000
