{
    "name": "allknower",
    "version": "0.1.0",
    "description": "AI orchestration service for AllCodex — the intelligence layer behind the All Reach grimoire",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "db:generate": "bunx prisma generate",
        "db:migrate": "bunx prisma migrate dev",
        "db:migrate:prod": "bunx prisma migrate deploy",
        "db:studio": "bunx prisma studio",
        "db:reset": "bunx prisma migrate reset",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@bogeychan/elysia-etag": "^0.1.0",
        "@elysiajs/openapi": "^1.4.14",
        "@lancedb/lancedb": "^0.27.1",
        "@openrouter/sdk": "^0.10.2",
        "@prisma/client": "^6.3.0",
        "@xenova/transformers": "^2.17.2",
        "apache-arrow": "^21.1.0",
        "better-auth": "^1.5.6",
        "elysia": "^1.4.28",
        "elysia-background": "^1.2.1",
        "elysia-ip": "^1.0.10",
        "elysia-rate-limit": "^4.5.1",
        "elysia-xss": "^1.0.4",
        "elysiajs-helmet": "^1.0.4",
        "logixlysia": "^6.3.0",
        "openai": "^6.33.0",
        "p-limit": "^7.3.0",
        "tiktoken": "^1.0.22",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.9",
        "prisma": "^6.3.0",
        "typescript": "^6.0.2"
    },
    "patchedDependencies": {
        "elysia-background@1.2.1": "patches/elysia-background@1.2.1.patch"
    }
}