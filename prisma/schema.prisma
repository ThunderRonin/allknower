generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model BrainDumpHistory {
  id           String   @id @default(cuid())
  rawText      String
  rawTextHash  String?                    // SHA-256 of rawText for idempotency dedup
  parsedJson   Json
  notesCreated String[]
  notesUpdated String[]
  model        String
  tokensUsed   Int?
  createdAt    DateTime @default(now())

  @@index([rawTextHash, createdAt])
  @@map("brain_dump_history")
}

model LLMCallLog {
  id         String   @id @default(cuid())
  requestId  String?
  task       String                       // "brain-dump" | "consistency" | "suggest" | etc.
  model      String                       // model that actually handled the request
  tokensUsed Int
  latencyMs  Int
  createdAt  DateTime @default(now())

  @@index([task])
  @@index([createdAt])
  @@map("llm_call_log")
}

model RagIndexMeta {
  id         String   @id @default(cuid())
  noteId     String   @unique
  noteTitle  String
  embeddedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  chunkCount Int
  model      String

  @@map("rag_index_meta")
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

model RelationHistory {
  id           String   @id @default(cuid())
  sourceNoteId String
  targetNoteId String
  type         String
  description  String?
  createdAt    DateTime @default(now())

  @@map("relation_history")
}

// ── Tier 3: Session state for multi-turn context compaction ───────────────────

model LoreSession {
  id                String               @id @default(cuid())
  title             String?
  state             Json                 // LoreSessionState
  tokensAccumulated Int                  @default(0)
  compactionCount   Int                  @default(0)
  compactionFailed  Int                  @default(0)
  lockedAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          LoreSessionMessage[]

  @@map("lore_sessions")
}

model LoreSessionMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       String      // "user" | "assistant" | "system"
  content    String
  tokenCount Int         @default(0)
  metadata   Json?       // { model, latencyMs, ragChunksUsed, compacted: bool }
  createdAt  DateTime    @default(now())
  session    LoreSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("lore_session_messages")
}
