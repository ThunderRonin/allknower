generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  integrations  UserIntegration[]

  @@map("users")
}

model UserIntegration {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  baseUrl        String
  encryptedToken String
  tokenLast4     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider])
  @@map("user_integrations")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model BrainDumpHistory {
  id           String   @id @default(cuid())
  userId       String?
  rawText      String
  parsedJson   Json
  notesCreated String[]
  notesUpdated String[]
  model        String
  tokensUsed   Int?
  createdAt    DateTime @default(now())
  rawTextHash  String?

  @@index([userId])
  @@index([rawTextHash, createdAt])
  @@map("brain_dump_history")
}

model LLMCallLog {
  id         String   @id @default(cuid())
  userId     String?
  requestId  String?
  task       String
  model      String
  tokensUsed   Int
  inputTokens  Int?
  outputTokens Int?
  costUsd      Decimal? @db.Decimal(12, 8)
  latencyMs    Int
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([task])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("llm_call_log")
}

model RagIndexMeta {
  id         String   @id @default(cuid())
  noteId     String   @unique
  noteTitle  String
  embeddedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  chunkCount Int
  model      String

  @@map("rag_index_meta")
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

model RelationHistory {
  id           String   @id @default(cuid())
  userId       String?
  sourceNoteId String
  targetNoteId String
  type         String
  relationName String?
  description  String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("relation_history")
}

model RelationSuggestion {
  id          String   @id @default(cuid())
  noteId      String
  userId      String   @default("")
  contentHash String
  suggestions Json
  model       String
  tokensUsed  Int?
  latencyMs   Int?
  createdAt   DateTime @default(now())

  @@unique([noteId, userId])
  @@index([noteId, contentHash])
  @@map("relation_suggestions")
}

model LoreSession {
  id                String               @id @default(cuid())
  userId            String?
  title             String?
  state             Json
  tokensAccumulated Int                  @default(0)
  compactionCount   Int                  @default(0)
  compactionFailed  Int                  @default(0)
  lockedAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          LoreSessionMessage[]

  @@index([userId])
  @@map("lore_sessions")
}

model LoreSessionMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       String
  content    String
  tokenCount Int         @default(0)
  metadata   Json?
  createdAt  DateTime    @default(now())
  session    LoreSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("lore_session_messages")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model BrainDumpJob {
  id                String    @id @default(cuid())
  userId            String
  batchId           String
  rawText           String
  parentNoteId      String?
  mode              String    // "auto" | "review"
  status            String    // "queued" | "running" | "done" | "failed" | "cancelled"
  error             String?
  resultHistoryId   String?   // FK to BrainDumpHistory.id on success
  position          Int       // order within batch
  createdAt         DateTime  @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?

  @@index([status, createdAt])  // worker polling
  @@index([userId, batchId])    // batch queries
  @@index([batchId])
  @@map("brain_dump_jobs")
}

model BrainDumpRevisionLink {
  id                  String   @id @default(cuid())
  brainDumpHistoryId  String
  noteId              String
  revisionIdBefore    String?
  revisionIdAfter     String?
  action              String   // "created" | "updated" | "noop"
  createdAt           DateTime @default(now())

  @@index([brainDumpHistoryId])
  @@index([noteId])
  @@map("brain_dump_revision_links")
}

model ModelPricing {
  id               String   @id @default(cuid())
  modelId          String   @unique
  pricePerMInput   Decimal  @db.Decimal(14, 8)
  pricePerMOutput  Decimal  @db.Decimal(14, 8)
  lastFetched      DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@map("model_pricing")
}

model UserBudget {
  id                 String   @id @default(cuid())
  userId             String   @unique
  dailyBudgetUsd     Decimal? @db.Decimal(10, 4)
  monthlyBudgetUsd   Decimal? @db.Decimal(10, 4)
  alertEmail         String?
  digestLastSentDate String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@map("user_budgets")
}
